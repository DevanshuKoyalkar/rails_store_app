<div class="product-detail">
  <h1><%= @product.name %></h1>

  <div class="product-layout">
    <div class="product-image-container">
      <%= image_tag @product.featured_image, class: "detail-image" if @product.featured_image.attached? %>
    </div>

    <div class="product-info-container">
      <div class="description">
        <%= @product.description %>
      </div>

      <div class="product-meta">
        <p class="inventory">In Stock: <%= @product.inventory %></p>
        <p class="detail-price"><%= number_to_currency(@product.price) %></p>
      </div>

      <div class="actions">
        <% if authenticated? %>
          <%= link_to "Edit", edit_product_path(@product), class: "btn btn-secondary" %>
          <%= button_to "Delete Product", product_path(@product), 
              method: :delete, 
              class: "btn btn-danger",
              data: { turbo_confirm: "Are you sure you want to delete this product?" } %>
        <% end %>
        <%= link_to "Back to Products", products_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>

<style>
.product-detail {
  background: white;
  border-radius: 8px;
  padding: 2rem;
  margin-top: 1rem;
}

.product-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-top: 2rem;
}

.detail-image {
  width: 100%;
  max-height: 500px;
  object-fit: contain;
  border-radius: 8px;
}

.product-meta {
  margin: 2rem 0;
}

.detail-price {
  font-size: 1.8rem;
  color: #B12704;
  font-weight: bold;
}

.inventory {
  color: #007600;
  font-size: 1.1rem;
}

.description {
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--amazon-grey);
}

.actions {
  display: flex;
  gap: 1rem;
  margin-top: 2rem;
}

@media (max-width: 768px) {
  .product-layout {
    grid-template-columns: 1fr;
  }
}
</style>
